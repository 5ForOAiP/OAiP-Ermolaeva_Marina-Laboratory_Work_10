<Window x:Class="lab10OAiP.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab10OAiP"
        mc:Ignorable="d"
        Title="RegisterWindow" Height="450" Width="800">
    <ScrollViewer>
                <StackPanel>
                    <TextBlock Text="Регистрация нового студента" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

                    <TextBlock Text="Имя *" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtFirstName" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Text="Фамилия" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtLastName" Margin="0,0,0,10" Padding="5"/>

                 
                    <TextBlock Text="Дата рождения" FontWeight="Bold" Margin="0,5"/>
                    <DatePicker x:Name="dpBirthDate" Margin="0,0,0,10"/>

                 
                    <TextBlock Text="Email *" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtEmail" Margin="0,0,0,10" Padding="5"/>

                  
                    <TextBlock Text="Пароль *" FontWeight="Bold" Margin="0,5"/>
                    <PasswordBox x:Name="txtPassword" Margin="0,0,0,10" Padding="5"/>

                  
                    <TextBlock Text="Телефон" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtPhone" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Text="Факультет *" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtFaculty" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Text="Группа *" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtGroup" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Text="Курс (1-6)*" FontWeight="Bold" Margin="0,5"/>
                    <TextBox x:Name="txtCourse" Margin="0,0,0,10" Padding="5"/>

                    <TextBlock Text="Дата поступления" FontWeight="Bold" Margin="0,5"/>
                    <DatePicker x:Name="dpEnrollment" Margin="0,0,0,20"/>

                   
                    <Button x:Name="btnRegister" 
                    Content="ЗАРЕГИСТРИРОВАТЬСЯ" 
                    Click="BtnRegister_Click"
                    Height="45" 
                    Background="#F3D98F" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="14"
                    Margin="0,10"/>

                    <TextBlock Text="* — обязательные поля" 
                       FontSize="11" 
                       Foreground="Gray" 
                       HorizontalAlignment="Center" 
                       Margin="0,10"/>
                </StackPanel>
            </ScrollViewer>
        </Window>
