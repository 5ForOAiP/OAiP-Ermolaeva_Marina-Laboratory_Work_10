<Window x:Class="lab10OAiP.VerifyCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab10OAiP"
        mc:Ignorable="d"
        Title="VerifyCodeWindow" Height="450" Width="800">
    <StackPanel>
            <TextBlock Text="Подтверждение" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

            <TextBlock Text="Введите код из письма" 
                   Margin="0,10,0,5"/>
            <TextBox x:Name="txtCode" 
                 FontSize="14" 
                 Padding="5"
                 MaxLength="6"/>

            <TextBlock Text="Новый пароль" 
                   Margin="0,15,0,5"/>
            <PasswordBox x:Name="txtNewPassword" 
                     FontSize="14" 
                     Padding="5"/>

            <TextBlock Text="Повторите пароль" 
                   Margin="0,15,0,5"/>
            <PasswordBox x:Name="txtConfirmPassword" 
                     FontSize="14" 
                     Padding="5"/>

            <Button x:Name="btnReset" 
                Content="СБРОСИТЬ ПАРОЛЬ" 
                Click="BtnReset_Click"
                Height="40" 
                Margin="0,20,0,10"
                Background="#E36887" 
                Foreground="White" 
                FontWeight="Bold"/>
        </StackPanel>
    </Window>
