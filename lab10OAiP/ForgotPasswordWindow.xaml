<Window x:Class="lab10OAiP.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:lab10OAiP"
        mc:Ignorable="d"
        Title="ForgotPasswordWindow" Height="450" Width="800">

    <StackPanel>
                <TextBlock Text="Восстановление пароля" 
                   FontSize="20" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,20"/>

                <TextBlock Text="Введите ваш email" 
                   Margin="0,10,0,5"/>
                <TextBox x:Name="txtEmail" 
                 FontSize="14" 
                 Padding="5"/>

                <Button x:Name="btnSendCode" 
                Content="ОТПРАВИТЬ КОД" 
                Click="BtnSendCode_Click"
                Height="40" 
                Margin="0,20,0,10"
                Background="#F3D98F" 
                Foreground="White" 
                FontWeight="Bold"/>

                <Button x:Name="btnBack" 
                Content=" Вернуться ко входу" 
                Click="BtnBack_Click"
                Background="Transparent" 
                Foreground="Gray"/>
            </StackPanel>
        </Window>

